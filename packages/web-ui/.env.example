# Local exporter API used by the Transfer flow.
VITE_LOVABLE_EXPORTER_API_BASE_URL=http://127.0.0.1:8799

# Optional Supabase Auth gate for the standalone web UI.
# Leave these unset to run the page without sign-in.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional. Defaults to the current page URL.
VITE_SUPABASE_REDIRECT_URL=http://localhost:5173

# The test Cloudflare Turnstile Site Key that always succeeds
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Optional PostHog analytics for the standalone app.
# Leave VITE_POSTHOG_KEY unset to disable analytics entirely.
VITE_POSTHOG_KEY=phc_your_project_key

# Optional. Override this for EU PostHog or self-hosted PostHog.
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Optional. Set this when deploying the standalone app under a subpath.
# Example: /tools/lovable-cloud-to-supabase-exporter/
VITE_APP_BASE_PATH=/
